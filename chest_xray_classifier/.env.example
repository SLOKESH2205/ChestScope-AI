# Environment variables for Chest X-Ray Classifier

# Dataset paths
DATASET_PATH=./dataset
TRAIN_DIR=./dataset/train
VAL_DIR=./dataset/val
TEST_DIR=./dataset/test

# Model paths
MODEL_DIR=./model
MODEL_PATH=./model/chest_xray_model.keras
EFFNET_PATH=./model/chest_xray_efficientnet.keras

# Output directories
RESULTS_DIR=./results
REPORTS_DIR=./reports
LOG_DIR=./logs

# Database
DB_PATH=./logs/predictions.db

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_REGISTRY_URI=sqlite:///mlflow.db

# Model configuration
BATCH_SIZE=32
IMG_SIZE=224
NUM_CLASSES=4
SEED=42

# Training
EPOCHS_CNN=30
LR_CNN=0.001
EPOCHS_EFFNET_PHASE1=15
EPOCHS_EFFNET_PHASE2=10
LR_EFFNET_PHASE1=0.0001
LR_EFFNET_PHASE2=0.00001

# Prediction
CONFIDENCE_THRESHOLD=0.6
MC_DROPOUT_ITERS=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Optional: Create .env file by copying this and setting actual values
# Copy this file to .env and fill in actual paths and configuration
